#!/bin/sh -e

test -x /usr/sbin/install-docs && ( install-docs -r lct 2> /dev/null) || true

# Automatically added by dh_installinit
if [ -x "/etc/init.d/console-screen.sh" ] && [ "$1" = remove ]; then
	if [ -x "`which invoke-rc.d 2>/dev/null`" ]; then
		invoke-rc.d console-screen.sh stop || exit $?
	else
		/etc/init.d/console-screen.sh stop || exit $?
	fi
fi
# End automatically added section

