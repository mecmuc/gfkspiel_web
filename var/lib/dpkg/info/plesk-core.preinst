# vim:syntax=sh

core_start_std_psa_on_rollback()
{
	$PRODUCT_ROOT_D/rc.d/psa start
}

core_start_std_mailman_on_rollback()
{
	$PRODUCT_ROOT_D/rc.d/mailman start
}

core_groupadd_f()
{
    grep -q "^$1:" /etc/group || /usr/sbin/groupadd "$1"
}

stop_removed_httpsd()
{
	# cannot use rc.d script because it can be removed
	pidfile="$PRODUCT_ROOT_D/admin/logs/httpsd.pid"
	if test -f "$pidfile"; then
		httpsd_pid=`cat "$pidfile"`
		if test "$httpsd_pid" -gt 0 			&& ps -o command -p "$httpsd_pid" | grep -q httpsd
		then
			kill -TERM "$httpsd_pid"
		fi
	fi
}

maintainer_main_pre()
{
	ignore_miss_conf=1
	interactive_allowed=0
	mysql_unconfigured=1

	set_local_params
	set_ftpd_params

	get_config_parameters


	# debian will try upgrade unconfigured package
	# it is not an upgrade, actually
	if [ "X$do_upgrade" = "X1" ]; then
		if [ ! -s ${PRODUCT_ROOT_D}/version ]; then
			do_upgrade=0
		fi
	fi

# Upgrade psa -> plesk-core
	if [ "X$do_upgrade" = "X0" -a -s ${PRODUCT_ROOT_D}/version ]; then
			do_upgrade=1
	fi

	preinstall_checks

	if [ "X$do_upgrade" = "X1" ]; then

		set_mysqld_params

		# Check mysqld status for non-debian based distros
		if [ "$linux_distr" != "debian" -a "$linux_distr" != "ubuntu" ]; then
			pleskrc mysql start 1 || die "Unable to start mysql service"
		fi

		if [ -s ${PRODUCT_ROOT_D}/version ]; then
			cp ${PRODUCT_ROOT_D}/version ${PRODUCT_ROOT_D}/version.upg
		fi
	fi

	set_apache_accounts
	necessary_system_accounts_prep_install

	if [ "X$do_upgrade" = "X1" ]; then
		if [ -s ${PRODUCT_ROOT_D}/version ]; then
			get_prev_version $PRODUCT_ROOT_D
		fi
		set_mysql_auth
		prepare_upgrader
	fi

	core_groupadd_f psacln
	add_login_shell "$PRODUCT_ROOT_D/bin/chrootsh"

	p_echo "Create PPSB support group"
    group_op "psasb" "search" false
    add_user_to_group "psaadm" "psasb"
    add_user_to_group "www-data" "psasb"
}

core_register_bsd_compat()
{
    local compat4_script compat5_script

    register_service compat4x
    register_service compat5x

    compat4_script="`find $PRODUCT_RC_D -type f -name "*compat4x*" | head -1`"
    compat5_script="`find $PRODUCT_RC_D -type f -name "*compat5x*" | head -1`"

    if [ -f $PRODUCT_RC_D/$compat4_script -a "X$compat4_script" != "X" ]; then
       $PRODUCT_RC_D/$compat4_script start
    fi
    if [ -f $PRODUCT_RC_D/$compat5_script -a "X$compat5_script" != "X" ]; then
       $PRODUCT_RC_D/$compat5_script start
    fi
}

core_start_product_on_rollback()
{
	start_after_install=1 # for start_product_now
	start_product_now
}

sso_port_change_prep()
{
	# SSO port is changed in sw-sso 2.6, i.e. on upgrade to 10.2.0
	[ "X$do_upgrade" = "X1" ] || return 0
	[ ! -f /etc/sw-cp-server/applications.d/00-sso-cpserver.conf ] || return 0

	# signal to SSO that we upgrade plesk.conf in 10.2.0
	touch /tmp/pp-bootstrapper-upgrade-cpserver-configs.flag

	# signal to Billing the need to perform upgrade actions
	touch /tmp/pp-bootstrapper-change-sso-port.flag

	# actual upgrade for Plesk is done in db_upgrade_sso_port_1010
}

core_bootstrapper_prep_install()
{
	selinux_init
	maintainer_main_pre

	# stop product
	define_start_script
	if [ -f $START_SH ]; then
		# schedule product start on rollback if product is started
		$START_SH status && transaction_add_rollback_action "core_start_product_on_rollback"
		stop_before_upgrade
	else
		stop_removed_httpsd

	fi

	# Perform safe prep-install db actions
	safe_prep_db

	sso_port_change_prep
	selinux_fix_booleans

	selinux_close
}


if [ "X${PLESK_INSTALLER_DEBUG}" != "X" ]; then
    set -x
fi

if [ "X${PLESK_INSTALLER_STRICT_MODE}" != "X" ]; then
	set -e
fi

do_upgrade=0
product_build="ubuntu12.04.build110120608.16"

case "$1" in
	install)
		package_script_safe_run core_install_pre core_bootstrapper_prep_install plesk-core 11.0.9 ubuntu12.04.build110120608.16 "$1"
		;;
	upgrade)
		# We are the new upgrading package
		do_upgrade=1
		prev_version="${2%%-*}"
		package_script_safe_run core_upgrade_new_pre core_bootstrapper_prep_install plesk-core 11.0.9 ubuntu12.04.build110120608.16 "$1"
		;;
	abort-upgrade)
		;;
	*)
		echo "Unknown operation: preinst $*"
		exit 1
		;;
esac
