	cd /opt/psa/admin/lib/python && rm -f ./*.pyc
}

set_relay_opts()
{
	local controls="$PRODUCT_ROOT_D/var/root.controls.lock"
	if [ ! -s "$controls" ]; then
		echo "/server/mail.php3:relay_open" > $controls
	fi
}

clean_backend_cache()
{
	db_do "DELETE FROM BackendCache"
	rm -f "$PRODUCT_ROOT_D/tmp/*.cache"
}

clean_upgrade_info()
{
	db_do "TRUNCATE smb_productUpgrades; TRUNCATE smb_componentUpdates;"
}

smb_init_log()
{
	touch $PRODUCT_ROOT_D/admin/logs/panel.log
	chmod 0640 $PRODUCT_ROOT_D/admin/logs/panel.log
	chown psaadm:0 $PRODUCT_ROOT_D/admin/logs/panel.log
