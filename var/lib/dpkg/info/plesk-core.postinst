	[ -f /tmp/pp-bootstrapper-upgrade-cpserver-configs.flag ] && rm -rf /tmp/pp-bootstrapper-upgrade-cpserver-configs.flag
	[ -f /tmp/pp-bootstrapper-change-sso-port.flag ] && rm -f /tmp/pp-bootstrapper-change-sso-port.flag

	# actual upgrade for Plesk is done in db_upgrade_sso_port_1010
}

core_bootstrapper_post_install()
{
	set_local_params
	necessary_system_accounts_post_install
	sso_port_change_post
	maintainer_main_post
}


if [ "X${PLESK_INSTALLER_DEBUG}" != "X" ]; then
    set -x
fi

if [ "X${PLESK_INSTALLER_STRICT_MODE}" != "X" ]; then
	set -e
fi

do_upgrade=0
product_build="ubuntu12.04.build110120608.16"

case "$1" in
	configure)
		if [ "X$2" != "X" ]; then
			# We are the new upgrading package
			do_upgrade=1
			prev_version="${2%%-*}"
			package_script_safe_run_with_report core_upgrade_new_post core_bootstrapper_post_install plesk-core 11.0.9 ubuntu12.04.build110120608.16 "$1"
		else
			package_script_safe_run_with_report core_install_post core_bootstrapper_post_install plesk-core 11.0.9 ubuntu12.04.build110120608.16 "$1"
		fi
		;;
	abort-upgrade)
		;;
	abort-remove)
		;;
	abort-deconfigure)
		;;
	*)
		echo "Unknown operation: postinst $*"
		exit 1
		;;
esac
